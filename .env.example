# =============================================================================
# Copy to .env for local dev or Docker deployment on your VPS.
# Never commit .env or real secrets to git.
# =============================================================================

# --- Database (PostgreSQL) ---
# Docker Compose: point at the `db` service on the internal network (no SSL needed).
# DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/POSTGRES_DB
# DIRECT_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/POSTGRES_DB
#
# Managed Postgres (Neon, etc.): pooled URL for app runtime, direct URL for migrations.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Docker Compose only — used by the `db` service (must match credentials in DATABASE_URL).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-use-a-long-random-password
POSTGRES_DB=vrajpharma

# --- Auth ---
# Required. At least 32 characters (HS256 JWT in httpOnly cookie).
JWT_SECRET=change-me-at-least-32-characters-long

# Google OAuth (Web client). In Google Console, add redirect URIs for each host you use:
#   https://your-domain.com/api/auth/google/callback
#   http://localhost:3000/api/auth/google/callback
# (Must match the URL in the browser — www vs non-www matters.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public site URL (OAuth redirects, password-reset links). Set to your production domain on VPS.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Password reset (Resend). Dev: use onboarding@resend.dev after signing up at resend.com
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Rate limiting (Upstash Redis — required in production for auth routes)
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Payments ---
# Set to true when Razorpay checkout is live. When false, orders are saved but checkout shows "coming soon".
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# --- Razorpay ---
# Test keys until live keys are approved. Webhook secret from Razorpay Dashboard.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Catalog ---
# Product.price is list price in INR (before catalog discount %).

# --- App ---
# Docker Compose sets NODE_ENV=production in the image; use development for local npm run dev.
NODE_ENV=development
