# =============================================================================
# Copy to .env locally. On Vercel: Project → Settings → Environment Variables.
# Never commit .env or real secrets to git.
# =============================================================================

# --- Database (PostgreSQL / Neon) ---
# Pooled URL for the app (Prisma queries)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Direct URL for migrations (Neon: use non-pooler host)
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- Auth ---
# Required. At least 32 characters (HS256 JWT in httpOnly cookie).
JWT_SECRET=

# Google OAuth (Web client). In Google Console, add redirect URIs for each host you use:
#   https://your-domain.com/api/auth/google/callback
#   http://localhost:3000/api/auth/google/callback
# (Must match the URL in the browser — www vs non-www matters.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional; OAuth uses the live request host. Useful for other features if needed.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Password reset (Resend). Dev: use onboarding@resend.dev after signing up at resend.com
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Rate limiting (Upstash Redis — required on Vercel production for auth routes)
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Payments ---
# Set to true when Razorpay checkout is live. When false, orders are saved but checkout shows "coming soon".
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# --- Razorpay ---
# Test keys until live keys are approved. Webhook secret from Razorpay Dashboard.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Catalog ---
# Product.price is list price in INR (before catalog discount %).

# --- App ---
# production on Vercel sets secure cookies automatically
NODE_ENV=development
