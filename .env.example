# Copy to .env and set your database URL
# PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# MySQL:      mysql://USER:PASSWORD@HOST:PORT/DATABASE
# SQLite:     file:./dev.db (and set provider = "sqlite" in schema.prisma)

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
